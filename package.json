{
  "name": "@ryandur/sand",
  "version": "5.4.0",
  "type": "module",
  "description": "helper objects and functions",
  "homepage": "https://ryandur.github.io/sand/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RyanDur/sand.git"
  },
  "main": "dist/sand.umd.cjs",
  "module": "dist/sand.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/sand.js",
      "require": "./dist/sand.umd.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "result",
    "maybe",
    "asyncresult",
    "functional"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "prepublishOnly": "npm run build",
    "deploy": "gh-pages -d docs",
    "test:coverage": "npm test -- src/lib --coverage",
    "ci": "npm run test:coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --type-aware",
    "docs": "npx --yes -p typedoc@0.28.20 -p typescript@6.0.2 typedoc"
  },
  "author": "Ryan Durling",
  "license": "MIT",
  "devDependencies": {
    "@faker-js/faker": "^10.5.0",
    "@typescript/typescript6": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.10",
    "gh-pages": "^6.1.1",
    "msw": "^2.15.0",
    "oxlint": "^1.74.0",
    "oxlint-tsgolint": "^0.25.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.10"
  },
  "overrides": {}
}
